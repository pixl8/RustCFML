<cfscript>
// Example 07: Boolean Logic
// Boolean operations and comparisons

x = true;
y = false;

writeOutput("true AND false = ");
writeOutput(x && y);

writeOutput("true OR false = ");
writeOutput(x || y);

writeOutput("NOT false = ");
writeOutput(!y);

writeOutput("10 > 5 = ");
writeOutput(10 > 5);

writeOutput("10 == 10 = ");
writeOutput(10 == 10);

writeOutput("10 != 5 = ");
writeOutput(10 != 5);
</cfscript>
